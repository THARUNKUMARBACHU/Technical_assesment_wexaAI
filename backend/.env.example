# Application
APP_NAME=analytics-platform
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# Server
HOST=0.0.0.0
PORT=8000

# Database (use postgresql:// — the app auto-converts for async/sync drivers)
DATABASE_URL=postgresql://analytics:analytics_dev_pass@localhost:5432/analytics_platform
# DATABASE_URL_SYNC= (optional override for sync driver, derived from DATABASE_URL if not set)

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# CORS
CORS_ORIGINS=["http://localhost:3000"]

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# SMTP (Gmail - optional, logs to console if not set)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_SENDER_NAME=LoopBoard Analytics

# Frontend URL (for invite links in emails)
FRONTEND_URL=http://localhost:3000
